# This file should NOT be committed to version control.
# Use .env.example as a template and fill in your own values locally.
# 
# ⚠️ SECURITY WARNING:
# - .env files containing real credentials should never be committed to git
# - This file is listed in .gitignore to prevent accidental commits
# - If you accidentally committed credentials, rotate them immediately in Supabase
#
# Local setup:
# 1. Copy .env.example to .env
# 2. Fill in your Supabase credentials from https://supabase.com/dashboard
# 3. Never commit .env to git

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
